<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext (HTTP) traffic so the widget can reach self-hosted Actual Budget
    instances that are not behind TLS (e.g. on a local network).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ActualBudgetAndroidWidgets"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- Widget configuration activity – no launcher intent filter -->
        <activity
            android:name=".ui.configure.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.ActualBudgetAndroidWidgets">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- AppWidget receiver backed by Jetpack Glance -->
        <receiver
            android:name=".widget.BudgetWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/budget_widget_info" />
        </receiver>

        <!-- Category group health bars widget -->
        <receiver
            android:name=".widget.CategoryGroupWidgetReceiver"
            android:exported="true"
            android:label="@string/category_widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/category_widget_info" />
        </receiver>

    </application>

</manifest>
